# Plantilla de variables de entorno. Copiar a .env y rellenar.

# Carpeta donde el operador deposita PDFs/imágenes a procesar
CAPTURADOR_INPUT_DIR=documentos_ingresados

# Carpeta donde se escriben los Excel de salida
CAPTURADOR_OUTPUT_DIR=output

# Carpeta de cuarentena para documentos que requieren revisión manual
CAPTURADOR_QUARANTINE_DIR=quarantine

# Ruta absoluta al binario de Tesseract
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# Directorio de traineddata (debe incluir spa.traineddata)
TESSDATA_PREFIX=C:\Users\Tranquilidad\.tessdata\

# Nivel de logging: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Redis (para workers y colas)
REDIS_URL=redis://localhost:6379/0